generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id         String   @id @default(cuid())
  name       String
  contact    String?
  favorite   String?
  interests  String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}